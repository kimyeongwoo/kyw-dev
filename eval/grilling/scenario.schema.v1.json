{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyw-dev.local/eval/grilling/scenario.v1.schema.json",
  "title": "kyw-grilling evaluation scenario v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "category",
    "title",
    "subject",
    "repository",
    "repositoryFacts",
    "unresolvedDecisions",
    "scriptedUserReplies",
    "expectedCriticalBehaviors",
    "budgets"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "category": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "content"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "content": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "repositoryFacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "statement",
          "evidencePath",
          "forbiddenQuestionSignals"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "evidencePath": {
            "type": "string"
          },
          "forbiddenQuestionSignals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "unresolvedDecisions": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "prompt",
          "dependsOn",
          "signals"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "signals": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "scriptedUserReplies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "afterAssistantTurn",
          "text",
          "settles"
        ],
        "properties": {
          "afterAssistantTurn": {
            "type": "integer",
            "minimum": 1
          },
          "text": {
            "type": "string"
          },
          "settles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "expectedCriticalBehaviors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "requiredSignals"
      ],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "requiredSignals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "byAssistantTurn",
              "signals",
              "critical"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "byAssistantTurn": {
                "type": "integer",
                "minimum": 1
              },
              "signals": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "critical": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxAssistantTurns",
        "maxOutputTokens"
      ],
      "properties": {
        "maxAssistantTurns": {
          "type": "integer",
          "minimum": 1
        },
        "maxOutputTokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
