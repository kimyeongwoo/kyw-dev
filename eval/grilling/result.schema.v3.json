{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyw-dev.local/eval/grilling/result.v3.schema.json",
  "title": "kyw-grilling evaluation result v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "status",
    "startedAt",
    "completedAt",
    "variant",
    "scenario",
    "codex",
    "isolation",
    "session",
    "turns",
    "usage",
    "grade"
  ],
  "properties": {
    "schemaVersion": {
      "const": 3
    },
    "runId": {
      "type": "string",
      "pattern": "^[0-9]{17}-(kyw|upstream)-[a-z0-9-]+-[0-9a-f]{8}$"
    },
    "status": {
      "enum": [
        "completed",
        "completed_with_violations"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "skillName",
        "sourcePath",
        "skillSha256",
        "upstreamCommit"
      ],
      "properties": {
        "id": {
          "enum": [
            "kyw",
            "upstream"
          ]
        },
        "skillName": {
          "type": "string"
        },
        "sourcePath": {
          "type": "string"
        },
        "skillSha256": {
          "$ref": "#/$defs/sha256"
        },
        "upstreamCommit": {
          "oneOf": [
            {
              "$ref": "#/$defs/gitSha"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "sha256"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "codex": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "model",
        "config",
        "capabilities"
      ],
      "properties": {
        "version": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "initialSandbox",
            "resumeUsesPersistedSessionSandbox",
            "ignoreUserConfig",
            "ignoreRules",
            "strictConfig",
            "shellEnvironmentInherit",
            "reasoningEffort"
          ],
          "properties": {
            "initialSandbox": {
              "const": "read-only"
            },
            "resumeUsesPersistedSessionSandbox": {
              "const": true
            },
            "ignoreUserConfig": {
              "const": true
            },
            "ignoreRules": {
              "const": true
            },
            "strictConfig": {
              "const": true
            },
            "shellEnvironmentInherit": {
              "const": "none"
            },
            "reasoningEffort": {
              "enum": [
                "minimal",
                "low",
                "medium",
                "high",
                "xhigh"
              ]
            }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "jsonl",
            "outputLastMessage",
            "readOnlySandbox",
            "ignoreUserConfig",
            "ignoreRules",
            "explicitSessionResume"
          ],
          "properties": {
            "jsonl": {
              "const": true
            },
            "outputLastMessage": {
              "const": true
            },
            "readOnlySandbox": {
              "const": true
            },
            "ignoreUserConfig": {
              "const": true
            },
            "ignoreRules": {
              "const": true
            },
            "explicitSessionResume": {
              "const": true
            }
          }
        }
      }
    },
    "isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "temporaryGitRepository",
        "temporaryCodexHome",
        "temporaryUserHome",
        "normalUserConfigurationLoaded",
        "sandbox",
        "skillInstallCount",
        "installedSkillName",
        "skillInstallScope",
        "skillSourceRead",
        "fixtureSha256Before",
        "fixtureSha256After",
        "fixtureUnchanged",
        "gitStatusClean",
        "authMode",
        "authSourceUnchanged",
        "temporaryWorkspaceCleanedAfterRun"
      ],
      "properties": {
        "temporaryGitRepository": {
          "const": true
        },
        "temporaryCodexHome": {
          "const": true
        },
        "temporaryUserHome": {
          "const": true
        },
        "normalUserConfigurationLoaded": {
          "const": false
        },
        "sandbox": {
          "const": "read-only"
        },
        "skillInstallCount": {
          "type": "integer",
          "minimum": 0
        },
        "installedSkillName": {
          "type": "string"
        },
        "skillInstallScope": {
          "const": "repository"
        },
        "skillSourceRead": {
          "const": true
        },
        "fixtureSha256Before": {
          "$ref": "#/$defs/sha256"
        },
        "fixtureSha256After": {
          "$ref": "#/$defs/sha256"
        },
        "fixtureUnchanged": {
          "type": "boolean"
        },
        "gitStatusClean": {
          "type": "boolean"
        },
        "authMode": {
          "enum": [
            "none",
            "temporary-file-copy",
            "single-run-code-api-key"
          ]
        },
        "authSourceUnchanged": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "temporaryWorkspaceCleanedAfterRun": {
          "const": true
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "threadId",
        "resumeThreadIds",
        "resumedSameThread"
      ],
      "properties": {
        "threadId": {
          "type": "string"
        },
        "resumeThreadIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resumedSameThread": {
          "type": "boolean"
        }
      }
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/turn"
      }
    },
    "usage": {
      "$ref": "#/$defs/aggregateUsage"
    },
    "grade": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rubricId",
        "totalScore",
        "criticalViolations",
        "dimensions",
        "observations"
      ],
      "properties": {
        "rubricId": {
          "const": "kyw-grilling-rubric-v1"
        },
        "totalScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "criticalViolations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "detector",
              "details"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^CV-[0-9]{2}$"
              },
              "detector": {
                "type": "string"
              },
              "details": {
                "type": "string"
              }
            }
          }
        },
        "dimensions": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "weight",
              "score",
              "weightedScore"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "weight": {
                "type": "integer",
                "minimum": 1
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "weightedScore": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        },
        "observations": {
          "type": "object"
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "gitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "turnUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "reasoning_output_tokens"
      ],
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cached_input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "reasoning_output_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "aggregateUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputTokens",
        "cachedInputTokens",
        "outputTokens",
        "reasoningOutputTokens"
      ],
      "properties": {
        "inputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "cachedInputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "reasoningOutputTokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "kind",
        "userMessage",
        "startedAt",
        "completedAt",
        "threadId",
        "eventsFile",
        "finalMessageFile",
        "finalMessage",
        "usage",
        "diagnostic"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "kind": {
          "enum": [
            "initial",
            "resume"
          ]
        },
        "userMessage": {
          "type": "string"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "threadId": {
          "type": "string"
        },
        "eventsFile": {
          "type": "string",
          "pattern": "^turn-[0-9]{2}\\.events\\.jsonl$"
        },
        "finalMessageFile": {
          "type": "string",
          "pattern": "^turn-[0-9]{2}\\.final\\.txt$"
        },
        "finalMessage": {
          "type": "string"
        },
        "usage": {
          "$ref": "#/$defs/turnUsage"
        },
        "diagnostic": {
          "type": "string"
        }
      }
    }
  }
}
