{
  "name": "kyw-dev",
  "version": "0.1.0",
  "description": "A spec-driven development workflow plugin for Codex.",
  "private": false,
  "keywords": [
    "codex",
    "agent-skills",
    "spec-driven-development",
    "developer-workflow"
  ],
  "homepage": "https://github.com/kimyeongwoo/kyw-dev#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimyeongwoo/kyw-dev.git"
  },
  "bugs": {
    "url": "https://github.com/kimyeongwoo/kyw-dev/issues"
  },
  "type": "module",
  "bin": {
    "kyw-dev": "bin/kyw-dev.mjs"
  },
  "files": [
    ".codex-plugin/",
    "bin/",
    "src/",
    "skills/",
    "templates/",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "licenses/"
  ],
  "scripts": {
    "test": "node --test",
    "lint": "node ./scripts/lint.mjs",
    "format:check": "node ./scripts/format-check.mjs",
    "pack:check": "node ./scripts/pack-check.mjs",
    "verify:plan": "node ./scripts/verification-plan.mjs",
    "check": "npm test && npm run lint && npm run format:check && npm run pack:check",
    "eval:audit:smoke": "node ./scripts/audit-smoke.mjs",
    "eval:grilling:unit": "node --test test/grilling-eval.test.mjs",
    "eval:grilling:smoke": "node ./scripts/grilling-eval.mjs smoke",
    "eval:grilling:compare": "node ./scripts/grilling-eval.mjs compare",
    "eval:grilling:report": "node ./scripts/grilling-eval.mjs report",
    "release:candidate": "node ./scripts/packed-release-check.mjs",
    "release:ci": "npm run check && npm run release:candidate",
    "release:check": "npm run release:ci && npm publish --dry-run --json"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Kim Yeongwoo"
  },
  "license": "MIT"
}
